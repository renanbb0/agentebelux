# ──────────────────────────────────────────────
# Agente Belux — Variáveis de Ambiente
# Copie este arquivo para .env e preencha os valores
# NUNCA versione o arquivo .env
# ──────────────────────────────────────────────

# WooCommerce REST API
WC_BASE_URL=https://seusite.com/wp-json/wc/v3
WC_CONSUMER_KEY=ck_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
WC_CONSUMER_SECRET=cs_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Z-API (WhatsApp)
ZAPI_INSTANCE_ID=seu_instance_id
ZAPI_TOKEN=seu_token
ZAPI_CLIENT_TOKEN=seu_client_token

# Gemini (IA Conversacional e TTS)
# Gere sua chave em: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=AIzaSy_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TTS_ENABLED=false
#
# O projeto usa ElevenLabs para voz. TTS_VOICE do Gemini nao e utilizado.
# Vozes disponíveis: Aoede (padrão), Charon, Fenrir, Kore, Puck
TTS_VOICE=Aoede

# Supabase (banco de dados — sessões, learnings, pedidos)
SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ElevenLabs TTS
ELEVENLABS_API_KEY=sk_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
ELEVENLABS_VOICE_ID=your_voice_id_here
ELEVENLABS_MODEL_ID=eleven_multilingual_v2
ELEVENLABS_OUTPUT_FORMAT=mp3_44100_128
ELEVENLABS_STABILITY=0.35
ELEVENLABS_SIMILARITY_BOOST=0.80
ELEVENLABS_STYLE=0.35
ELEVENLABS_SPEED=1.00
ELEVENLABS_USE_SPEAKER_BOOST=true

# Servidor
PORT=3000

# Notificação de pedidos — número da consultora (com DDI, sem + ou espaços)
# ADMIN_PHONE=5585999999999
